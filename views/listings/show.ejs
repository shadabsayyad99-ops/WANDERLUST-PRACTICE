<% layout("/layouts/boilerplate") %>

    <div class="row mt-3">
        <div class="col-8 offset-3 pt-3 ">

            <h3>
                <b>
                    <%=listing.title %>
                </b>
            </h3>
        </div>
        <div class="card col-6 offset-3 show-card listing-card">
            <img src="<%=listing.image.url %>" class="card-img-top show-img" alt="listing_image">
            <div class="card-body">
                <br>
                <p class="card-text"> <i>Owned By : <b>
                            <%= listing.owner.username %>
                        </b></i></p>
                <p class="card-text"> <i>
                        <%=listing.description %>
                    </i></p>
                <p class="card-text"> <i> &#8377 <%=listing.price.toLocaleString("en-IN") %> </i></p>
                <p class="card-text"> <i>
                        <%=listing.location %>
                    </i></p>
                <p class="card-text"> <i>
                        <%=listing.country %>
                    </i></p>

            </div>
        </div>

        <% if(currUser && listing.owner._id.equals(currUser._id)) { %>
            <div class="btns">
                <a href="/listings/<%=listing._id%>/edit" class="btn btn-dark col-1 offset-3 edit-btn">Edit</a>

                <form method="POST" action="/listings/<%= listing._id%>?_method=DELETE">
                    <button class="btn btn-dark  offset-5">Delete</button>
                </form>
            </div>
            <% } %>

                <div class="col-8 offset-3 mb-3">

                    <% if(currUser) { %>
                        <hr>
                        <h4> Leave a Comment</h4>
                        <form action="/listings/<%= listing.id %>/reviews" method="post" novalidate
                            class="needs-validation">

                            <div class="mb-3 mt-3">
                                <label for="rating" class="form-label">Rating </label>
                                <fieldset class="starability-slot">
                                    <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]"
                                        value="1" checked aria-label="No rating." />
                                    <input type="radio" id="first-rate1" name="review[rating]" value="1" />
                                    <label for="first-rate1" title="Terrible">1 star</label>
                                    <input type="radio" id="first-rate2" name="review[rating]" value="2" />
                                    <label for="first-rate2" title="Not good">2 stars</label>
                                    <input type="radio" id="first-rate3" name="review[rating]" value="3" />
                                    <label for="first-rate3" title="Average">3 stars</label>
                                    <input type="radio" id="first-rate4" name="review[rating]" value="4" />
                                    <label for="first-rate4" title="Very good">4 stars</label>
                                    <input type="radio" id="first-rate5" name="review[rating]" value="5" />
                                    <label for="first-rate5" title="Amazing">5 stars</label>
                                </fieldset>
                            </div>

                            <div class="mb-3 mt-3">
                                <label for="comment" class="form-label">Comment </label>
                                <textarea name="review[comment]" id="comment" cols="30" rows="6" class="form-control"
                                    required></textarea>
                                <div class="valid-feedback"> Review looks good</div>
                                <div class="invalid-feedback"> Please Enter some Comments for Review </div>
                            </div>
                            <button class="btn btn-outline-dark"> Submit</button>

                        </form>
                        <% } %>


                            <% if(listing.reviews.length> 0) {%>
                                <hr>

                                <h4>ALL REVIEWS </h4>
                                <div class="row mt-3">
                                    <% for(review of listing.reviews){ %>
                                        <div class="card col-5 mb-3 ms-3">
                                            <div class="card-body">
                                                <h5 class="card-title mt-2">
                                                    <%= review.author.username %>
                                                </h5>
                                                <p class="card-text">
                                                <p class="starability-result card-text" data-rating=<%=review.rating %>>

                                                </p>
                                                </p>
                                                <p class="card-text">
                                                    <%= review.comment %>
                                                </p>


                                            </div>

                                            <form
                                                action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE "
                                                method="post" class="mb-3 mt-2">
                                                <button class="btn btn-sm btn-dark mt-3">Delete</button>
                                            </form>
                                        </div>
                                        <%} %>
                                </div>
                                <% } %>
                </div>
    </div>

    <div class="col-8 offset-3 mt-4">
        <hr>
        <h3>Villa Location</h3>

        <div id="map"></div>
        <br>
    </div>


    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"
        integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI"
        crossorigin="anonymous"></script>
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>



    <script>
        const latitude = Number("<%= listing.latitude %>");
        const longitude = Number("<%= listing.longitude %>");

        console.log(latitude, longitude);

        const map = L.map("map").setView([latitude, longitude], 13);

        L.tileLayer("https://tile.openstreetmap.org/{z}/{x}/{y}.png", {
            maxZoom: 19,
            attribution: "&copy; OpenStreetMap contributors"
        }).addTo(map);

        L.marker([latitude, longitude])
            .addTo(map)
            .bindPopup("<b><%= listing.title %></b>")
            .bindPopup(`
                    <b><%= listing.title %></b><br>
                    <%= listing.location %>, <%= listing.country %>
                    <br>
                    Exact Location Will Be Provided After Booking 
                    `)
    </script>